
# Private RSSHub instance base URL (self-hosted; see SPEC §10.8).
# Referenced from config/dimensions.yaml as ${RSSHUB_BASE} — unset = those sources skip.
RSSHUB_BASE=http://your-rsshub-host:1200

# Civitai API key (free: civitai.com → Account Settings → API Keys) — the social
# dimension's Civitai card; anonymous API calls are Cloudflare-blocked. Unset = card skips.
CIVITAI_API_KEY=your-civitai-api-key
