{%- macro stat_row(stats) -%}
<ul class="stats">
{%- for key, icon, label in [("views", "view", "views"), ("likes", "like", "likes"), ("comments", "comment", "comments"), ("saves", "save", "saves"), ("shares", "share", "shares")] if key in stats -%}
<li class="stat" aria-label="{{ stats[key] }} {{ label }}"><svg class="stat-ic" aria-hidden="true"><use href="#ic-{{ icon }}"/></svg>{{ stats[key] | compact }}</li>
{%- endfor -%}
</ul>
{%- endmacro -%}
{%- macro bi(zh, en, fallback) -%}
{%- if zh and en -%}<span lang="zh">{{ zh }}</span><span lang="en">{{ en }}</span>{%- else -%}{{ fallback }}{%- endif -%}
{%- endmacro -%}
{%- macro wh(path) -%}
{%- set d = image_dims.get(path) -%}
{%- if d %} width="{{ d[0] }}" height="{{ d[1] }}"{% endif -%}
{%- endmacro -%}
{%- macro title_bi(item) -%}
{{ bi(item.i18n.get("zh", {}).get("title"), item.i18n.get("en", {}).get("title"), item.title) }}
{%- endmacro -%}
{%- macro blurb_p(item, cls="item-summary") -%}
{%- set izh = item.i18n.get("zh", {}) -%}
{%- set ien = item.i18n.get("en", {}) -%}
{%- set b_zh = izh.get("summary") or izh.get("raw_text") -%}
{%- set b_en = ien.get("summary") or ien.get("raw_text") -%}
{%- set fallback = item | blurb -%}
{%- if (b_zh and b_en) or fallback %}<p class="{{ cls }}">{{ bi(b_zh, b_en, fallback) }}</p>{% endif -%}
{%- endmacro -%}
<!DOCTYPE html>
<html lang="zh-Hans">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ issue.title_i18n.get("zh", issue.title) }} — {{ issue.date }}</title>
  <style>{{ css | safe }}</style>
</head>
<body>
  <input type="checkbox" id="lang-en" class="lang-switch" aria-label="English / 中文">
  {% if dimensions | sum(attribute="items", start=[]) | selectattr("stats") | first %}
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><symbol id="ic-view" viewBox="0 0 24 24"><path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></symbol><symbol id="ic-like" viewBox="0 0 24 24"><path fill="currentColor" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></symbol><symbol id="ic-comment" viewBox="0 0 24 24"><path fill="currentColor" d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></symbol><symbol id="ic-save" viewBox="0 0 24 24"><path fill="currentColor" d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></symbol><symbol id="ic-share" viewBox="0 0 24 24"><path fill="currentColor" d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></symbol></svg>
  {% endif %}
  <header class="masthead">
    <label class="lang-toggle" for="lang-en" title="中文 / English"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M4.545 6.714 4.11 8H3l1.862-5h1.284L8 8H6.833l-.435-1.286zm1.634-.736L5.5 3.956h-.049l-.679 2.022z"/><path d="M0 2a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v3h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-3H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zm7.138 9.995q.289.451.63.846c-.748.575-1.673 1.001-2.768 1.292.178.217.451.635.555.867 1.125-.359 2.08-.844 2.886-1.494.777.665 1.739 1.165 2.93 1.472.133-.254.414-.673.629-.89-1.125-.253-2.057-.694-2.82-1.284.681-.747 1.222-1.651 1.621-2.757H14V8h-3v1.047h.765c-.318.844-.74 1.546-1.272 2.13a6 6 0 0 1-.415-.492 2 2 0 0 1-.94.31"/></svg></label>
    <h1 class="masthead-title">{{ bi(issue.title_i18n.get("zh"), issue.title, issue.title) }}</h1>
    {% if issue.subtitle %}<p class="masthead-subtitle">{{ bi(issue.subtitle_i18n.get("zh"), issue.subtitle, issue.subtitle) }}</p>{% endif %}
    <div class="masthead-rule">
      <span><span lang="zh">第 {{ issue.week }} 期</span><span lang="en">Issue {{ issue.week }}</span></span>
      <span>{{ issue | week_range }}</span>
    </div>
  </header>

  {% if issue.tldr and render_tldr %}
  <section class="tldr">
    <p class="kicker">TL;DR</p>
    <p class="tldr-body">{{ bi(issue.tldr_i18n.get("zh"), issue.tldr_i18n.get("en"), issue.tldr) }}</p>
  </section>
  {% endif %}

  {% set lead = dimensions[0].items[0] if dimensions and dimensions[0].items and dimensions[0].layout != "by-source" else None %}
  {% if lead %}
  <article class="lead">
    <p class="kicker">{{ bi(dimensions[0].name_i18n.get("zh"), dimensions[0].name_i18n.get("en"), dimensions[0].name) }}</p>
    {% if lead.image %}<img class="lead-image" src="{{ lead.image }}" fetchpriority="high" decoding="async"{{ wh(lead.image) }} alt="">{% endif %}
    <h2 class="lead-title"><a href="{{ lead.url }}">{{ title_bi(lead) }}</a></h2>
    {{ blurb_p(lead, cls="lead-summary") }}
    {% if lead.source %}<p class="item-source">{{ lead.source }}</p>{% endif %}
  </article>
  {% endif %}

  <main class="sections">
    {% for dim in dimensions %}
    {% set outer = loop %}
    {% if dim.items or dim.notes %}
    <section class="dimension">
      <h3 class="dimension-name">{{ bi(dim.name_i18n.get("zh"), dim.name_i18n.get("en"), dim.name) }}</h3>
      {% if dim.blurb %}<p class="dimension-blurb">{{ bi(dim.blurb_i18n.get("zh"), dim.blurb_i18n.get("en"), dim.blurb) }}</p>{% endif %}
      {% for note in dim.notes %}<p class="dimension-note">{{ note }}</p>{% endfor %}
      {% if dim.layout == "by-source" %}
      <div class="labs{% if dim.items | selectattr("stats") | first %} labs--media{% endif %}">
        {% for label, group_items in dim.items | groupby_order('group') %}
        {% set logo = dim.logos.get(label) %}
        <div class="lab">
          <div class="lab-rail">
            {% if label %}<div class="lab-name">{{ label }}</div>{% endif %}
            {% if logo %}<img class="lab-logo" src="{{ logo }}" loading="lazy" decoding="async" alt="{{ label }} logo">{% endif %}
          </div>
          <div class="lab-items">
            {% for item in group_items %}
            {% if (dim.items | selectattr("stats") | first) and item.image %}
            <article class="media-item">
              <a class="media-tile" href="{{ item.url }}">
                {% if item.image %}<img class="media-thumb" src="{{ item.image }}" loading="lazy" decoding="async"{{ wh(item.image) }} alt="">{% endif %}
                {% if item.stats %}<span class="media-metrics">{% if "likes" in item.stats %}<span class="mm"><svg class="mm-ic" aria-hidden="true"><use href="#ic-like"/></svg>{{ item.stats.likes | compact }}</span>{% endif %}{% if "comments" in item.stats %}<span class="mm"><svg class="mm-ic" aria-hidden="true"><use href="#ic-comment"/></svg>{{ item.stats.comments | compact }}</span>{% endif %}</span>{% endif %}
                {% if item.creator %}<span class="media-cap"><span class="media-creator">{{ item.creator }}</span></span>{% endif %}
              </a>
              <div class="media-body">
                <h5 class="item-title"><a href="{{ item.url }}">{{ title_bi(item) }}</a></h5>
                {{ blurb_p(item) }}
                <p class="item-link"><a href="{{ item.url }}">{{ item.source or item.url }}</a>{% if item.published %} · <span class="item-date">{{ item.published }}</span>{% endif %}</p>
              </div>
            </article>
            {% else %}
            <article class="item">
              {% if item.image %}<img class="item-image" src="{{ item.image }}" loading="lazy" decoding="async"{{ wh(item.image) }} alt="">{% endif %}
              <h5 class="item-title"><a href="{{ item.url }}">{{ title_bi(item) }}</a></h5>
              {{ blurb_p(item) }}
              <p class="item-link"><a href="{{ item.url }}">{{ item.source or item.url }}</a>{% if item.published %} · <span class="item-date">{{ item.published }}</span>{% endif %}</p>
            </article>
            {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="items">
        {% for item in dim.items %}
        {% if not (outer.first and loop.first) %}
        <article class="item">
          {% if item.image %}<img class="item-image" src="{{ item.image }}" loading="lazy" decoding="async"{{ wh(item.image) }} alt="">{% endif %}
          <h4 class="item-title"><a href="{{ item.url }}">{{ title_bi(item) }}</a></h4>{% if item.stats %}{{ stat_row(item.stats) }}{% endif %}
          {{ blurb_p(item) }}
          {% if item.source %}<p class="item-source">{{ item.source }}</p>{% endif %}
        </article>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </section>
    {% endif %}
    {% endfor %}
  </main>

  <footer class="colophon">
    <p>{{ bi(issue.title_i18n.get("zh"), issue.title, issue.title) }} · <span lang="zh">第 {{ issue.week }} 期</span><span lang="en">Issue {{ issue.week }}</span> · {{ issue | week_range }}</p>
  </footer>
</body>
</html>
