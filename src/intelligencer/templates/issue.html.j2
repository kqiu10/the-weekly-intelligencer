{%- macro stat_row(stats) -%}
<ul class="stats">
{%- for key, icon, label in [("views", "view", "views"), ("likes", "like", "likes"), ("comments", "comment", "comments"), ("saves", "save", "saves"), ("shares", "share", "shares")] if key in stats -%}
<li class="stat" aria-label="{{ stats[key] }} {{ label }}"><svg class="stat-ic" aria-hidden="true"><use href="#ic-{{ icon }}"/></svg>{{ stats[key] | compact }}</li>
{%- endfor -%}
</ul>
{%- endmacro -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ issue.title }} — {{ issue.date }}</title>
  <style>{{ css | safe }}</style>
</head>
<body>
  {% if dimensions | sum(attribute="trends", start=[]) | selectattr("heat_tier") | first %}
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><symbol id="flame" viewBox="0 0 24 24"><path fill="#e8291c" d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67zM11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></symbol></svg>
  {% endif %}
  {% if dimensions | sum(attribute="items", start=[]) | selectattr("stats") | first %}
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><symbol id="ic-view" viewBox="0 0 24 24"><path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></symbol><symbol id="ic-like" viewBox="0 0 24 24"><path fill="currentColor" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></symbol><symbol id="ic-comment" viewBox="0 0 24 24"><path fill="currentColor" d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></symbol><symbol id="ic-save" viewBox="0 0 24 24"><path fill="currentColor" d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></symbol><symbol id="ic-share" viewBox="0 0 24 24"><path fill="currentColor" d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></symbol></svg>
  {% endif %}
  <header class="masthead">
    <h1 class="masthead-title">{{ issue.title }}</h1>
    {% if issue.subtitle %}<p class="masthead-subtitle">{{ issue.subtitle }}</p>{% endif %}
    <div class="masthead-rule">
      <span>Issue {{ issue.week }}</span>
      <span>{{ issue | week_range }}</span>
    </div>
  </header>

  {% if issue.tldr and render_tldr %}
  <section class="tldr">
    <p class="kicker">TL;DR</p>
    <p class="tldr-body">{{ issue.tldr }}</p>
  </section>
  {% endif %}

  {% set lead = dimensions[0].items[0] if dimensions and dimensions[0].items and dimensions[0].layout != "by-source" else None %}
  {% if lead %}
  <article class="lead">
    <p class="kicker">{{ dimensions[0].name }}</p>
    {% if lead.image %}<img class="lead-image" src="{{ lead.image }}" alt="">{% endif %}
    <h2 class="lead-title"><a href="{{ lead.url }}">{{ lead.title }}</a></h2>
    {% set lead_blurb = lead | blurb %}
    {% if lead_blurb %}<p class="lead-summary">{{ lead_blurb }}</p>{% endif %}
    {% if lead.source %}<p class="item-source">{{ lead.source }}</p>{% endif %}
  </article>
  {% endif %}

  <main class="sections">
    {% for dim in dimensions %}
    {% set outer = loop %}
    <section class="dimension">
      <h3 class="dimension-name">{{ dim.name }}</h3>
      {% if dim.blurb %}<p class="dimension-blurb">{{ dim.blurb }}</p>{% endif %}
      {% for note in dim.notes %}<p class="dimension-note">{{ note }}</p>{% endfor %}
      {% if dim.trends | selectattr("heat_tier") | list %}
      <div class="trend-strip">
        <p class="kicker">Heating up</p>
        <ul class="trend-list">
          {% for t in dim.trends if t.heat_tier %}
          <li class="trend">
            <span class="flames">{% for _ in range(t.heat_tier) %}<svg class="flame" aria-hidden="true"><use href="#flame"/></svg>{% endfor %}</span>
            <span class="trend-descriptor">{{ t.descriptor }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if dim.layout == "by-source" %}
      <div class="labs{% if dim.items | selectattr("stats") | first %} labs--media{% endif %}">
        {% for label, group_items in dim.items | groupby_order('group') %}
        {% set logo = dim.logos.get(label) %}
        <div class="lab">
          <div class="lab-rail">
            {% if label %}<div class="lab-name">{{ label }}</div>{% endif %}
            {% if logo %}<img class="lab-logo" src="{{ logo }}" alt="{{ label }} logo">{% endif %}
          </div>
          <div class="lab-items">
            {% for item in group_items %}
            {% if (dim.items | selectattr("stats") | first) and item.image %}
            <article class="media-item">
              <a class="media-tile" href="{{ item.url }}">
                {% if item.image %}<img class="media-thumb" src="{{ item.image }}" alt="">{% endif %}
                {% if item.stats %}<span class="media-metrics">{% if "likes" in item.stats %}<span class="mm"><svg class="mm-ic" aria-hidden="true"><use href="#ic-like"/></svg>{{ item.stats.likes | compact }}</span>{% endif %}{% if "comments" in item.stats %}<span class="mm"><svg class="mm-ic" aria-hidden="true"><use href="#ic-comment"/></svg>{{ item.stats.comments | compact }}</span>{% endif %}</span>{% endif %}
                {% if item.creator %}<span class="media-cap"><span class="media-creator">{{ item.creator }}</span></span>{% endif %}
              </a>
              <div class="media-body">
                <h5 class="item-title"><a href="{{ item.url }}">{{ item.title }}</a></h5>
                {% set item_blurb = item | blurb %}
                {% if item_blurb %}<p class="item-summary">{{ item_blurb }}</p>{% endif %}
                <p class="item-link"><a href="{{ item.url }}">{{ item.source or item.url }}</a>{% if item.published %} · <span class="item-date">{{ item.published }}</span>{% endif %}</p>
              </div>
            </article>
            {% else %}
            <article class="item">
              {% if item.image %}<img class="item-image" src="{{ item.image }}" alt="">{% endif %}
              <h5 class="item-title"><a href="{{ item.url }}">{{ item.title }}</a></h5>
              {% set item_blurb = item | blurb %}
              {% if item_blurb %}<p class="item-summary">{{ item_blurb }}</p>{% endif %}
              <p class="item-link"><a href="{{ item.url }}">{{ item.source or item.url }}</a>{% if item.published %} · <span class="item-date">{{ item.published }}</span>{% endif %}</p>
            </article>
            {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="items">
        {% for item in dim.items %}
        {% if not (outer.first and loop.first) %}
        <article class="item">
          {% if item.image %}<img class="item-image" src="{{ item.image }}" alt="">{% endif %}
          <h4 class="item-title"><a href="{{ item.url }}">{{ item.title }}</a></h4>{% if item.stats %}{{ stat_row(item.stats) }}{% endif %}
          {% set item_blurb = item | blurb %}
          {% if item_blurb %}<p class="item-summary">{{ item_blurb }}</p>{% endif %}
          {% if item.source %}<p class="item-source">{{ item.source }}</p>{% endif %}
        </article>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </section>
    {% endfor %}
  </main>

  <footer class="colophon">
    <p>{{ issue.title }} · Issue {{ issue.week }} · {{ issue | week_range }}</p>
  </footer>
</body>
</html>
